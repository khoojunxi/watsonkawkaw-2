# Required — OpenAI vision (GPT-4o) for roof + obstacle detection
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=replace_with_your_openai_api_key

# Optional — Replicate token for Meta SAM2 obstacle mask refinement.
# Without it, obstacle detection falls back to OpenAI-only.
# Get one at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=replace_with_your_replicate_api_token

# Optional — override the OpenAI vision model (defaults to gpt-4o)
# OPENAI_VISION_MODEL=gpt-4o

# Optional — set to "false" to use a faster single-pass analysis instead of the
# default two-pass (locate + analyze) workflow.
# ANALYZE_TWO_PASS=true
